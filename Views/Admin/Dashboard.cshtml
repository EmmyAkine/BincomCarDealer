@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="wrap">
    <div class="page-head">
        <p class="kicker">Staff Area</p>
        <h1>Dashboard</h1>
        <p>Manage inventory and respond to customer inquiries.</p>
    </div>

    <div class="dash-grid">
        <a href="@Url.Action("Upload", "Admin")" class="dash-card">
            <i class="bi bi-plus-circle dash-ic"></i>
            <h3>Upload a car</h3>
            <p>Add a new vehicle to the lot.</p>
        </a>

        <a href="@Url.Action("ManageCars", "Admin")" class="dash-card">
            <i class="bi bi-card-list dash-ic"></i>
            <h3>Manage cars</h3>
            <p>Edit, update, or remove listings.</p>
        </a>

        <a href="@Url.Action("Inquiries", "Admin")" class="dash-card">
            <i class="bi bi-envelope-open dash-ic"></i>
            <h3>Inquiries</h3>
            <p>See who's interested in what.</p>
        </a>

        <a href="@Url.Action("Logout", "Admin")" class="dash-card danger">
            <i class="bi bi-box-arrow-right dash-ic"></i>
            <h3>Log out</h3>
            <p>End your admin session.</p>
        </a>
    </div>
</div>
