@model List<BincomCarDealer.Models.CarInquiry>

@{
    ViewData["Title"] = "Inquiries";
}

<div class="wrap">
    <a href="@Url.Action("Dashboard", "Admin")" class="back-link" style="margin-top:1.5rem;">
        <i class="bi bi-arrow-left"></i> Back to dashboard
    </a>

    <div class="page-head" style="padding-top:0;">
        <p class="kicker">Customer Activity</p>
        <h1>Inquiries</h1>
    </div>

    <div class="admin-table-wrap">
        @if (Model.Any())
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Message</th>
                        <th>Car</th>
                        <th>Submitted</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inquiry in Model)
                    {
                        <tr>
                            <td>@inquiry.Name</td>
                            <td><a href="mailto:@inquiry.Email" class="mail-link">@inquiry.Email</a></td>
                            <td style="max-width:280px;">@inquiry.Message</td>
                            <td>
                                <a href="@Url.Action("Details", "Cars", new { id = inquiry.CarId })" target="_blank" rel="noopener" class="mail-link">
                                    #@inquiry.CarId <i class="bi bi-box-arrow-up-right" style="font-size:0.7rem;"></i>
                                </a>
                            </td>
                            <td class="num-cell">@inquiry.SubmittedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <table class="admin-table">
                <tbody>
                    <tr class="empty-table-row">
                        <td colspan="5">No inquiries yet.</td>
                    </tr>
                </tbody>
            </table>
        }
    </div>
</div>
