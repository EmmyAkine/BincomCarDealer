@model BincomCarDealer.Models.CarItem

@{
    ViewData["Title"] = "Edit Car";
}

<div class="wrap">
    <a href="@Url.Action("ManageCars", "Admin")" class="back-link" style="margin-top:1.5rem;">
        <i class="bi bi-arrow-left"></i> Back to manage cars
    </a>

    <div class="page-head" style="padding-top:0;">
        <p class="kicker">Editing #@Model.Id</p>
        <h1>@Model.Year @Model.Make @Model.Model</h1>
    </div>

    <div class="form-card" style="max-width:560px; margin-bottom:3rem;">
        <form asp-action="EditCarDetails" asp-controller="Admin" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ImagePath" />
            <input type="hidden" asp-for="UploadedAt" />

            <div class="field-row">
                <div class="field">
                    <label asp-for="Make">Make</label>
                    <input asp-for="Make" />
                </div>
                <div class="field">
                    <label asp-for="Model">Model</label>
                    <input asp-for="Model" />
                </div>
            </div>

            <div class="field-row">
                <div class="field">
                    <label asp-for="Year">Year</label>
                    <input asp-for="Year" type="number" min="1900" max="2027" />
                </div>
                <div class="field">
                    <label asp-for="BodyStyle">Body style</label>
                    <input asp-for="BodyStyle" />
                </div>
            </div>

            <div class="field-row">
                <div class="field">
                    <label asp-for="Price">Price (₦)</label>
                    <input asp-for="Price" type="number" step="0.01" min="0" />
                </div>
                <div class="field">
                    <label asp-for="Mileage">Mileage (km)</label>
                    <input asp-for="Mileage" type="number" min="0" />
                </div>
            </div>

            <div class="field">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" rows="4"></textarea>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="current-image">
                    <label>Current photo</label>
                    <img src="@Model.ImagePath" alt="Current vehicle photo" />
                </div>
            }

            <div class="field">
                <label>Replace photo</label>
                <div class="file-drop">
                    <input type="file" name="Image" accept="image/*" />
                    <span class="hint">Leave empty to keep the current photo.</span>
                </div>
            </div>

            <div style="display:flex; gap:0.6rem;">
                <button type="submit" class="btn btn-accent" style="flex:1;">
                    <i class="bi bi-check2"></i> Save changes
                </button>
                <a href="@Url.Action("ManageCars", "Admin")" class="btn btn-ghost" style="flex:1; text-align:center;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
