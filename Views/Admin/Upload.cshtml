@{
    ViewData["Title"] = "Upload Car";
}

<div class="wrap">
    <a href="@Url.Action("Dashboard", "Admin")" class="back-link" style="margin-top:1.5rem;">
        <i class="bi bi-arrow-left"></i> Back to dashboard
    </a>

    <div class="page-head" style="padding-top:0;">
        <p class="kicker">New Listing</p>
        <h1>Upload a car</h1>
    </div>

    <div class="form-card" style="max-width:560px; margin-bottom:3rem;">
        <form method="post" asp-action="Upload" asp-controller="Admin" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="field-row">
                <div class="field">
                    <label for="Make">Make</label>
                    <input type="text" id="Make" name="Make" placeholder="Toyota" required />
                </div>
                <div class="field">
                    <label for="Model">Model</label>
                    <input type="text" id="Model" name="Model" placeholder="RAV4" required />
                </div>
            </div>

            <div class="field-row">
                <div class="field">
                    <label for="Year">Year</label>
                    <input type="number" id="Year" name="Year" min="1900" max="2027" required />
                </div>
                <div class="field">
                    <label for="BodyStyle">Body style</label>
                    <input type="text" id="BodyStyle" name="BodyStyle" placeholder="SUV" required />
                </div>
            </div>

            <div class="field-row">
                <div class="field">
                    <label for="Price">Price (₦)</label>
                    <input type="number" id="Price" name="Price" step="0.01" min="0" required />
                </div>
                <div class="field">
                    <label for="Mileage">Mileage (km)</label>
                    <input type="number" id="Mileage" name="Mileage" min="0" required />
                </div>
            </div>

            <div class="field">
                <label for="Description">Description</label>
                <textarea id="Description" name="Description" rows="4" placeholder="Condition, features, service history..."></textarea>
            </div>

            <div class="field">
                <label>Vehicle photo</label>
                <div class="file-drop">
                    <input type="file" name="Image" accept="image/*" required />
                    <span class="hint">JPG or PNG, this becomes the main listing photo.</span>
                </div>
            </div>

            <button type="submit" class="btn btn-accent btn-block">
                <i class="bi bi-upload"></i> Add to inventory
            </button>
        </form>
    </div>
</div>
