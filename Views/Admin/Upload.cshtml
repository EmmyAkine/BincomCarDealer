@{
    ViewData["Title"] = "Upload Car";
}

<div style="max-width:500px; margin: 3rem auto; font-family: sans-serif;">
    <h2>Upload New Car</h2>

    <form method="post" asp-action="Upload" asp-controller="Admin" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div style="margin-bottom:1rem;">
            <label>Car Name</label><br />
            <input type="text" name="name" required style="width:100%; padding:0.5rem;" />
        </div>

        <div style="margin-bottom:1rem;">
            <label>Brand</label><br />
            <input type="text" name="brand" required style="width:100%; padding:0.5rem;" />
        </div>

        <div style="margin-bottom:1rem;">
            <label>Price (₦)</label><br />
            <input type="number" name="price" step="0.01" required style="width:100%; padding:0.5rem;" />
        </div>

        <div style="margin-bottom:1rem;">
            <label>Description</label><br />
            <textarea name="description" rows="4" style="width:100%; padding:0.5rem;"></textarea>
        </div>

        <div style="margin-bottom:1rem;">
            <label>Image</label><br />
            <input type="file" name="image" accept="image/*" required />
        </div>

        <button type="submit" style="padding:0.5rem 1.5rem;">Upload Car</button>
    </form>

    <p style="margin-top:1rem;"><a asp-action="Dashboard" asp-controller="Admin">&larr; Back to Dashboard</a></p>
</div>
