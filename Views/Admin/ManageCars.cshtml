@model List<BincomCarDealer.Models.CarItem>

@{
    ViewData["Title"] = "Manage Cars";
}

<div class="wrap">
    <a href="@Url.Action("Dashboard", "Admin")" class="back-link" style="margin-top:1.5rem;">
        <i class="bi bi-arrow-left"></i> Back to dashboard
    </a>

    <div class="page-head" style="padding-top:0;">
        <p class="kicker">Inventory</p>
        <h1>Manage cars</h1>
    </div>

    <div class="admin-table-wrap">
        @if (Model.Any())
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Year</th>
                        <th>Make</th>
                        <th>Model</th>
                        <th>Price</th>
                        <th>Uploaded</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var car in Model)
                    {
                        <tr>
                            <td class="num-cell">@car.Year</td>
                            <td>@car.Make</td>
                            <td>@car.Model</td>
                            <td class="price-cell">₦@car.Price.ToString("N0")</td>
                            <td class="num-cell">@car.UploadedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <input type="checkbox" id="confirm-@car.Id" class="delete-check" style="display:none;" />

                                <div class="row-actions">
                                    <span class="normal-actions" style="display:flex; gap:0.4rem;">
                                        <a href="@Url.Action("EditCarDetails", "Admin", new { id = car.Id })" class="btn btn-ghost btn-sm">Edit</a>
                                        <label for="confirm-@car.Id" class="btn btn-danger btn-sm" style="cursor:pointer;">Delete</label>
                                    </span>

                                    <span class="confirm-delete">
                                        <span class="confirm-label">Sure?</span>
                                        <a href="@Url.Action("DeleteCar", "Admin", new { id = car.Id })" class="btn btn-accent btn-sm">Yes</a>
                                        <label for="confirm-@car.Id" class="btn btn-ghost btn-sm" style="cursor:pointer;">No</label>
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <table class="admin-table">
                <tbody>
                    <tr class="empty-table-row">
                        <td colspan="6">No cars uploaded yet.</td>
                    </tr>
                </tbody>
            </table>
        }
    </div>
</div>
