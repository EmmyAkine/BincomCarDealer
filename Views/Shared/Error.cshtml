@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="wrap auth-shell">
    <div class="form-card" style="max-width:480px; text-align:center;">
        <i class="bi bi-cone-striped" style="font-size:2.2rem; color:var(--accent); margin-bottom:1rem; display:block;"></i>

        <span class="auth-kicker">Something went wrong</span>
        <h1 style="margin-bottom:0.75rem;">We hit a pothole</h1>

        <p style="color:var(--text-dim); font-size:0.92rem; line-height:1.6; margin-bottom:1.5rem;">
            An unexpected error occurred while processing your request.
            It's logged, and we'll sort it out.
        </p>

        @if (Model != null && Model.ShowRequestId)
        {
            <p style="font-family:var(--font-mono); font-size:0.75rem; color:var(--text-dim); margin-bottom:1.5rem;">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }

        <a href="@Url.Action("Index", "Cars")" class="btn btn-accent btn-block">
            <i class="bi bi-arrow-left"></i> Back to inventory
        </a>
    </div>
</div>
