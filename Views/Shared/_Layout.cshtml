<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Bincom Car Dealer</title>
    <meta name="description" content="Browse quality vehicles. Real inventory, real pricing, no surprises." />

    <!-- Set theme before first paint — no flash of wrong theme -->
    <script>
        (function () {
            var match = document.cookie.match(/(?:^|; )theme=([^;]*)/);
            var saved = match ? decodeURIComponent(match[1]) : 'dark';
            document.documentElement.setAttribute('data-theme', saved);
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="icon" type="image/png" sizes="16x16" href="~/favicons/icons8-car-windows-11-color-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicons/icons8-car-windows-11-color-32.png" />
    <link rel="icon" type="image/png" sizes="72x72" href="~/favicons/icons8-car-windows-11-color-72.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="~/favicons/icons8-car-windows-11-color-96.png" />

    <link rel="apple-touch-icon" type="image/png" sizes="57x57" href="~/favicons/icons8-car-windows-11-color-57.png" />
    <link rel="apple-touch-icon" type="image/png" sizes="60x60" href="~/favicons/icons8-car-windows-11-color-60.png" />
    <link rel="apple-touch-icon" type="image/png" sizes="72x72" href="~/favicons/icons8-car-windows-11-color-72.png" />
    <link rel="apple-touch-icon" type="image/png" sizes="76x76" href="~/favicons/icons8-car-windows-11-color-76.png" />

    <meta name="msapplication-square70x70logo" content="/favicons/icons8-car-fluent-70.png" />

</head>
<body>

    <header class="site-header">
        <div class="nav-inner">

            <a href="@Url.Action("Index", "Cars")" class="brand">
                <span class="plate">NGN</span>
                <span>BINCOM&nbsp;MOTORS</span>
            </a>

            <div class="nav-right">
                <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark and light mode">
                    <i class="bi bi-sun-fill ic-sun"></i>
                    <i class="bi bi-moon-stars-fill ic-moon"></i>
                </button>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

        <footer class="site-footer">
            <div class="footer-inner">
                <div>
                <p style="font-style:italic; margin-bottom:0.3rem;">&ldquo;Every car here has a number worth checking. We just make sure you see it first.&rdquo;</p>
                <p style="font-size:0.75rem; margin-bottom:0.2rem;">&copy; @DateTime.Now.Year Bincom Car Dealer.</p>
                <p class="footer-credit">
                    <a target="_blank" rel="noopener" href="https://icons8.com/icon/fsoiqMUp0O4v/car">Car</a> icon by <a target="_blank" rel="noopener" href="https://icons8.com">Icons8</a>
                </p>
            </div>
                <div style="display:flex; align-items:center; gap:1rem;">
                <span class="plate">VIN-VERIFIED INVENTORY</span>
                <a href="@Url.Action("Privacy", "Cars")" style="font-size:0.75rem; color:var(--text-dim);">Privacy</a>
            @* <a href="@Url.Action("Login", "Admin")" style="font-size:0.75rem; color:var(--text-dim);">Staff</a> *@
        </div>
    </div>
    </footer>

    <script>
        // Theme toggle
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            document.cookie = 'theme=' + encodeURIComponent(theme) + ';path=/;max-age=31536000';
        }

        document.getElementById('themeToggle').addEventListener('click', function () {
            var current = document.documentElement.getAttribute('data-theme');
            setTheme(current === 'dark' ? 'light' : 'dark');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
