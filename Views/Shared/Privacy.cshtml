@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="wrap">
    <div class="page-head">
        <p class="kicker">Legal</p>
        <h1>Privacy policy</h1>
        <p>What we collect when you browse or send an inquiry, and what we do with it.</p>
    </div>

    <div class="form-card" style="max-width:680px; margin-bottom:4rem;">
        <div style="font-size:0.92rem; line-height:1.75; color:var(--text-dim);">

            <h3 style="font-family:var(--font-display); color:var(--text); font-size:1rem; margin-bottom:0.5rem;">
                What we collect
            </h3>
            <p style="margin-bottom:1.5rem;">
                When you submit an inquiry about a vehicle, we collect your name, email
                address, and the message you send. We don't ask for anything beyond
                what's needed to follow up with you about that specific car.
            </p>

            <h3 style="font-family:var(--font-display); color:var(--text); font-size:1rem; margin-bottom:0.5rem;">
                How we use it
            </h3>
            <p style="margin-bottom:1.5rem;">
                Inquiry details are used only to respond to your question about the
                vehicle you asked about. We don't sell, share, or use your information
                for marketing outside of that conversation.
            </p>

            <h3 style="font-family:var(--font-display); color:var(--text); font-size:1rem; margin-bottom:0.5rem;">
                What we don't do
            </h3>
            <p style="margin-bottom:1.5rem;">
                We don't track you across other sites, sell your data to third parties,
                or require an account to browse the inventory. Looking at cars stays
                anonymous; only submitting an inquiry shares your details with us.
            </p>

            <h3 style="font-family:var(--font-display); color:var(--text); font-size:1rem; margin-bottom:0.5rem;">
                Questions
            </h3>
            <p style="margin:0;">
                If you have questions about how your information is handled, reach out
                through any vehicle's inquiry form and mention it in your message.
            </p>

        </div>
    </div>
</div>
