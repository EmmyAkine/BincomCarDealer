@model List<BincomCarDealer.Models.CarItem>

@{
    ViewData["Title"] = "Inventory";
}

<div class="wrap">
    <div class="page-head">
        <p class="kicker">Current Inventory</p>
        <h1>Find your next car</h1>
        <p>Every listing shows the year, mileage, and price up front — no digging for the numbers that matter.</p>
    </div>

    <div class="inventory-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var car in Model)
            {
                var carTitle = $"{car.Year} {car.Make} {car.Model}";
                <div class="car-card">
                    <div class="car-photo @(string.IsNullOrEmpty(car.ImagePath) ? "empty" : "")">
                        @if (!string.IsNullOrEmpty(car.ImagePath))
                        {
                            <img src="@car.ImagePath" alt="@carTitle" />
                            @if (!string.IsNullOrEmpty(car.BodyStyle))
                            {
                                <span class="body-tag">@car.BodyStyle</span>
                            }
                        }
                        else
                        {
                            <span>NO PHOTO</span>
                        }
                    </div>

                    <div class="car-body">
                        <h3 class="car-title">@carTitle</h3>

                        <div class="spec-strip">
                            <div class="spec-cell">
                                <span class="spec-label">Year</span>
                                <span class="spec-value">@car.Year</span>
                            </div>
                            <div class="spec-cell">
                                <span class="spec-label">Miles</span>
                                <span class="spec-value">@car.Mileage.ToString("N0")</span>
                            </div>
                            <div class="spec-cell price">
                                <span class="spec-label">Price</span>
                                <span class="spec-value">₦@FormatShort(car.Price)</span>
                            </div>
                        </div>

                        <a href="@Url.Action("Details", "Cars", new { id = car.Id })" class="btn btn-accent btn-block">
                            View details <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-car-front ic"></i>
                <p>No cars on the lot right now. Check back soon.</p>
            </div>
        }
    </div>
</div>

@functions {
    string FormatShort(decimal price)
    {
        if (price >= 1_000_000)
            return (price / 1_000_000m).ToString("0.#") + "M";
        if (price >= 1_000)
            return (price / 1_000m).ToString("0.#") + "K";
        return price.ToString("N0");
    }
}