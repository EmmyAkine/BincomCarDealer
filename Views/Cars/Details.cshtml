@model BincomCarDealer.Models.CarItem

@{
    var carTitle = $"{Model.Year} {Model.Make} {Model.Model}";
    ViewData["Title"] = carTitle;
    bool showSuccess = TempData["InquirySuccess"] != null;
}

<div class="wrap">
    <a href="@Url.Action("Index", "Cars")" class="back-link" style="margin-top:1.5rem;">
        <i class="bi bi-arrow-left"></i> Back to inventory
    </a>

    <div class="details-grid">
        <div>
            <div class="details-photo">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="@carTitle" />
                }
            </div>
        </div>

        <div>
            <h1 class="details-title">@carTitle</h1>
            <p class="details-sub">@Model.BodyStyle</p>

            <div class="spec-strip large">
                <div class="spec-cell">
                    <span class="spec-label">Year</span>
                    <span class="spec-value">@Model.Year</span>
                </div>
                <div class="spec-cell">
                    <span class="spec-label">Mileage</span>
                    <span class="spec-value">@Model.Mileage.ToString("N0") km</span>
                </div>
                <div class="spec-cell price">
                    <span class="spec-label">Price</span>
                    <span class="spec-value">₦@Model.Price.ToString("N0")</span>
                </div>
            </div>

            @{
                var fullDesc = Model.Description ?? "";
                var isLong = fullDesc.Length > 280;
                var shortDesc = isLong ? fullDesc.Substring(0, 280).TrimEnd() + "…" : fullDesc;
            }

            @if (isLong)
            {
                <div class="details-desc" id="descShort">@shortDesc</div>
                <div class="details-desc" id="descFull" style="display:none;">@fullDesc</div>
                <button type="button" id="descToggle" class="btn btn-ghost btn-sm" style="margin-top:-1.25rem; margin-bottom:1.5rem;">
                    Read more <i class="bi bi-chevron-down"></i>
                </button>
            }
            else
            {
                <div class="details-desc">@fullDesc</div>
            }

            <div class="inquiry-box">
                @if (showSuccess)
                {
                    <div class="success-box">
                        <i class="bi bi-check-circle-fill ic"></i>
                        <div>
                            <strong>Inquiry sent</strong>
                            <p>We'll get back to you about the @Model.Make @Model.Model soon.</p>
                        </div>
                    </div>
                }
                else
                {
                    <h3>Interested in this car?</h3>
                    <form method="post" asp-action="Inquire" asp-controller="Cars">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="carId" value="@Model.Id" />

                        <div class="field">
                            <label for="name">Your name</label>
                            <input type="text" id="name" name="name" required />
                        </div>
                        <div class="field">
                            <label for="email">Your email</label>
                            <input type="email" id="email" name="email" required />
                        </div>
                        <div class="field">
                            <label for="message">Message</label>
                            <textarea id="message" name="message" rows="4" required placeholder="Ask about availability, financing, or schedule a viewing..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-accent btn-block">
                            <i class="bi bi-send"></i> Send inquiry
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Toggle full/short description
    var descToggle = document.getElementById('descToggle');
    if (descToggle) {
        descToggle.addEventListener('click', function () {
            var short = document.getElementById('descShort');
            var full = document.getElementById('descFull');
            var expanded = full.style.display !== 'none';

            short.style.display = expanded ? '' : 'none';
            full.style.display = expanded ? 'none' : '';
            descToggle.innerHTML = expanded
                ? 'Read more <i class="bi bi-chevron-down"></i>'
                : 'Show less <i class="bi bi-chevron-up"></i>';
        });
    }

    @if (showSuccess)
    {
        <text>
        // Just submitted an inquiry — scroll the success message into view
        // so it's obvious the page didn't just silently reload.
        document.addEventListener('DOMContentLoaded', function () {
            var successBox = document.querySelector('.success-box');
            if (successBox) {
                successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
        </text>
    }
</script>
}
